# =============================================================================
# Sovereign-AI v4.1.0-LTS — environment template (Docker Compose + local dev)
# =============================================================================
# Copy to .env and replace placeholders:
#   cp .env.example .env
#
# MANDATORY for docker compose up (zero-trust API + DB + Grafana):
#   POSTGRES_PASSWORD, JWT_SECRET_KEY, SOVEREIGN_API_KEY, GF_ADMIN_PASSWORD
#
# MANDATORY for production API behavior (also enforced when ENV=production):
#   JWT_SECRET_KEY, SOVEREIGN_API_KEY
#
# Optional: GROQ_API_KEY / Ollama when ENABLE_TIER3=true; REDIS_URL for rate limits.
# =============================================================================

# --- Core runtime (aligns with Helm deploy/helm/sovereign-ai/values.yaml env) ---
# production | development — production tightens JWT defaults and security checks
ENV=production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
# OTLP gRPC endpoint; leave empty if no collector on this host/network
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Zero-trust API (required for /api/detect and other protected routes) ---
JWT_SECRET_KEY=change-this-in-production
SOVEREIGN_API_KEY=your-sovereign-api-key
# Comma-separated paths bypassing API key/JWT (default matches Helm chart)
AUTH_EXEMPT_PATHS=/,/health,/docs,/openapi.json,/redoc,/metrics,/api/auth

# --- PostgreSQL (docker-compose builds DATABASE_URL from these; do not commit real .env) ---
POSTGRES_USER=llm_observability
POSTGRES_DB=llm_observability
POSTGRES_PASSWORD=your_secure_postgres_password
# Host port mapping (optional overrides for docker-compose.yml)
POSTGRES_PUBLISH_PORT=5454
API_PUBLISH_PORT=8080

# --- Grafana (docker-compose; maps to GF_SECURITY_ADMIN_PASSWORD) ---
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=your_grafana_password
GRAFANA_PUBLISH_PORT=3000
PROMETHEUS_PUBLISH_PORT=9090

# --- Feature flags (Helm featureFlags.*) ---
ENABLE_TIER3=true
STORE_RAW_LLM_RESPONSE=false
AIR_GAPPED_MODE=false
ANTHROPIC_MODERATION_LITE=false

# --- LLM providers (Tier 3 / moderation) ---
GROQ_API_KEY=your_groq_key_if_using
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Optional: Redis (rate limiting / cache); leave empty if unused ---
REDIS_URL=

# --- Legacy / alternate name (app reads ENV or ENVIRONMENT; keep aligned with ENV) ---
ENVIRONMENT=production

# --- Cache & embeddings (local / Tier 2 tuning) ---
CACHE_ENABLED=true
CACHE_TTL=3600
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_SIMILARITY_THRESHOLD=0.85
BLOCK_THRESHOLD=0.7
ALLOW_THRESHOLD=0.3

# --- Do NOT set in production: legacy seeding (removed from runtime defaults) ---
# SEED_DEFAULT_USERS=
